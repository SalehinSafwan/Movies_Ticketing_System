<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#18645A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="450px"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Card container -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:elevation="6dp"
            android:padding="16dp"
            app:cardBackgroundColor="#307670"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Title -->
                <TextView
                    android:id="@+id/receiptTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:paddingBottom="16dp"
                    android:text="🎟 Ticket Receipt"
                    android:textColor="#14213d"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <!-- Username -->
                <TextView
                    android:id="@+id/receiptUsername"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="6dp"
                    android:text="Username: "
                    android:textColor="#000000"
                    android:textSize="18sp" />

                <!-- Showtime -->
                <TextView
                    android:id="@+id/receiptShowtime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="6dp"
                    android:text="Showtime ID: "
                    android:textColor="#000000"
                    android:textSize="18sp" />

                <!-- PNRs -->
                <TextView
                    android:id="@+id/receiptPNRs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="6dp"
                    android:text="PNRs: "
                    android:textColor="#fca311"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- Seats -->
                <TextView
                    android:id="@+id/receiptSeats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="6dp"
                    android:text="Seats: "
                    android:textColor="#000000"
                    android:textSize="18sp" />

                <!-- Total Price -->
                <TextView
                    android:id="@+id/receiptTotal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="6dp"
                    android:text="Total Price: "
                    android:textColor="#e63946"
                    android:textSize="20sp"
                    android:textStyle="bold" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>